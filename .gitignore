# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# personal data exports — keep local
/Pokemon business - exported.csv
/poke-investor-transactions-*.csv

# python pipeline artifacts
/pipeline/.venv/
/pipeline/.pytest_cache/
/pipeline/.ruff_cache/
/pipeline/.mypy_cache/
__pycache__/

# uv lock is checked in by convention — let it through

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
