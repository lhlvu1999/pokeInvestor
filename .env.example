DATABASE_URL=postgres://poke:poke@localhost:5432/poke_investor

# Required only for the Python pipeline's `insights` phase. The Next.js app
# does not read this — leave blank if you only run discover/transcripts.
OPENAI_API_KEY=

# Point at a local OpenAI-compatible server (Ollama, LM Studio, llama.cpp).
# Leave unset to use api.openai.com. When set to a non-OpenAI URL, the
# pipeline auto-switches to `json_object` mode since strict structured
# outputs are an OpenAI-only feature. See pipeline/README.md for a
# step-by-step Ollama setup.
# OPENAI_BASE_URL=http://localhost:11434/v1
# PIPE_LLM_JSON_MODE=1   # force JSON mode regardless of base URL

# Per-environment LLM overrides — take precedence over whatever the active
# row in the `prompts` table has. Lets you keep the same prompt across dev
# and prod and just flip the model/temperature via env.
#   LLM_MODEL=qwen2.5:7b     # any non-empty value → overrides prompt.model
#   LLM_TEMPERATURE=0.1      # numeric → overrides prompt.temperature
#   LLM_TEMPERATURE=null     # literal "null" → omit temperature entirely
#                            # (needed for OpenAI o-series models)
# LLM_MODEL=
# LLM_TEMPERATURE=

# Optional pipeline tunables (see pipeline/README.md for full list).
# PIPE_DISCOVER_MAX=50
# PIPE_INSIGHTS_BATCH=25
# PIPE_HTTP_TIMEOUT_SEC=30

# Workarounds for YouTube IP bans on the transcript phase. Use one or both:
#   - YT_TRANSCRIPT_COOKIES: path to a Netscape-format cookies file exported
#     from a browser where you're logged into YouTube. Export with the
#     "cookies.txt" extension or `yt-dlp --cookies-from-browser chrome
#     --cookies cookies.txt`. Authenticated requests are throttled more
#     gently than anonymous ones.
#   - YT_TRANSCRIPT_PROXY: generic HTTP/SOCKS proxy URL applied to all
#     transcript fetches, e.g. http://user:pass@proxy:8080 or
#     socks5://host:1080. A residential proxy is the most reliable fix
#     for a hard IP ban.
# YT_TRANSCRIPT_COOKIES=
# YT_TRANSCRIPT_PROXY=
